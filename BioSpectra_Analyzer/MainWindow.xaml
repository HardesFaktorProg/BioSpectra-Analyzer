<Window x:Class="BioSpectraAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="clr-namespace:OxyPlot.Wpf;assembly=OxyPlot.Wpf"
        Title="BioSpectra Analyzer"
        Height="600" Width="950"
        Background="#0E0E10" Foreground="White"
        FontFamily="Segoe UI">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель управления -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
            <Button x:Name="BtnLoad" 
                    Content="📂 Load Spectrum" 
                    Width="160" Height="35" 
                    Margin="0 0 10 0" 
                    Background="#2E86DE" Foreground="White"
                    Click="BtnLoad_Click"/>

            <Button x:Name="BtnAnalyze" 
                    Content="🔍 Analyze" 
                    Width="120" Height="35"
                    Background="#00B894" Foreground="White"
                    Click="BtnAnalyze_Click"/>

            <TextBlock Text="{Binding ResultText}" 
                       FontSize="16" 
                       Margin="20 0 0 0"
                       VerticalAlignment="Center"
                       Foreground="#FDCB6E"/>
        </StackPanel>

        <!-- График спектра -->
        <Border Grid.Row="1" BorderBrush="#2D3436" BorderThickness="2" CornerRadius="8">
            <oxy:PlotView x:Name="SpectrumPlot"
                          Model="{Binding SpectrumModel}"
                          Background="#1A1A1D"/>
        </Border>

        <!-- Нижняя строка -->
        <TextBlock Grid.Row="2"
                   Text="© IBONH NAS of Ukraine — BioSpectra Analyzer"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Margin="0 5"
                   Opacity="0.6"/>
    </Grid>
</Window>
